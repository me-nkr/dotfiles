[include]
    path = ~/.gitconfig.private
[init]
	defaultBranch = main
[core]
	excludesFile = ~/.gitignore
[alias]
    graph = log --all --decorate --oneline --graph --format=format:'%C(yellow)%h%C(reset) %C(bold green)(%ar)%C(reset) by %C(dim white) %aN%C(reset)%C(auto)%d%C(reset)%n%C(white)%s%C(reset)%n'
